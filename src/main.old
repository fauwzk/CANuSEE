// ==== Area Chart History Buffer ====
#define AREA_CHART_HISTORY 105
struct AreaChartData
{
  double values[AREA_CHART_HISTORY];
  uint8_t currentIndex;
  bool initialized;
};
AreaChartData turboHistory = {{0}, 0, false};
